# Admin connection — used by seed.py to create tables, load data, and provision the reader role.
DATABASE_URL=postgresql+psycopg://genbi_admin:genbi_admin_dev@localhost:5433/genbi

# Read-only connection — used by the agent at runtime. SELECT-only.
READONLY_DATABASE_URL=postgresql+psycopg://genbi_reader:genbi_reader_dev@localhost:5433/genbi

# Claude API key — required by claude-agent-sdk and CI workflows.
ANTHROPIC_API_KEY=sk-ant-...

# Local Ollama embedding model — used by kb_search and the seed_kb script.
# Run `ollama pull nomic-embed-text` once before `python -m genbi.seed_kb`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
KB_TOP_K=5
